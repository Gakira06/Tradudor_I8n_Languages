# Ambiente da aplicação: development | production | test
NODE_ENV=development

# Porta onde a API será exposta
PORT=3000

# Conexão com PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=i18n_db
DB_USER=postgres
DB_PASSWORD=sua_senha_aqui

# Tamanho máximo do pool de conexões
DB_POOL_MAX=10

# ====== AUTO-TRADUÇÃO DE PRODUTOS ======
# O sistema padrão usa MyMemory (gratuito, sem configuração necessária)
#
# Para usar LibreTranslate self-hosted (recomendado para produção):
# 1. Instale LibreTranslate com Docker:
#    docker run -d --name libretranslate -p 5000:5000 libretranslate/libretranslate:latest
# 2. Descomente e configure a variável abaixo:
#
# LIBRETRANSLATE_URL=http://localhost:5000/translate
# LIBRETRANSLATE_API_KEY=sua_chave_api_opcional
