# Ambiente da aplicação: development | production | test
NODE_ENV=development

# Porta onde a API será exposta
PORT=3000

# Conexão com PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=i18n_db
DB_USER=postgres
DB_PASSWORD=sua_senha_aqui

# Tamanho máximo do pool de conexões
DB_POOL_MAX=10

# ====== AUTO-TRADUÇÃO DE PRODUTOS ======
# O sistema usa um provider de IA compatível com OpenAI Chat Completions.
#
# Exemplos compatíveis:
# - OpenAI
# - Gemini via OpenAI compatibility endpoint
# - OpenRouter
# - Groq
#
# Variáveis obrigatórias:
# AI_TRANSLATION_API_KEY=sua_chave_aqui
#
# Variáveis opcionais:
# AI_TRANSLATION_MODEL=gpt-4-turbo (padrão para OpenAI) ou gemini-2.0-flash
# AI_TRANSLATION_BASE_URL=https://api.openai.com/v1 (padrão para OpenAI)
#
# Exemplo 1 - OpenAI (recomendado):
# AI_TRANSLATION_API_KEY=sk-proj-...sua_chave_openai...
# AI_TRANSLATION_MODEL=gpt-4-turbo
# AI_TRANSLATION_BASE_URL=https://api.openai.com/v1
#
# Exemplo 2 - Gemini via OpenAI compatibility:
# AI_TRANSLATION_API_KEY=sua_chave_gemini
# AI_TRANSLATION_MODEL=gemini-2.0-flash
# AI_TRANSLATION_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
#
# Debug mode (opcional):
# I18N_DEBUG=1
