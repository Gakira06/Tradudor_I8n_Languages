{
  "name": "i18n-api",
  "version": "1.0.0",
  "description": "Microserviço centralizado de traduções (I18n API)",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "db:schema": "psql -U $PGUSER -d $PGDATABASE -f database/schema.sql",
    "db:seed": "psql -U $PGUSER -d $PGDATABASE -f database/seed.sql"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "pg": "^8.11.5"
  },
  "devDependencies": {
    "nodemon": "^3.1.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
